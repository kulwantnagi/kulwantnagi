# Required: Anthropic API key for Claude AI analysis
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: Maximum video file size in MB (default: 500)
MAX_VIDEO_SIZE_MB=500

# Optional: Frame extraction interval in seconds (default: 5)
FRAME_INTERVAL_SECONDS=5

# Optional: Maximum number of frames to analyze (default: 30)
MAX_FRAMES=30
